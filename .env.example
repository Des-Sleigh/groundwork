# Copy to .env (gitignored). Read by the Anthropic SDK + Groundwork.

# Required for real runs (research.py, the API server, real grounding).
ANTHROPIC_API_KEY=

# Optional: live web search via Tavily (https://tavily.com). Without it,
# search falls back to the local fixture corpus (offline/CI).
TAVILY_API_KEY=

# Optional overrides:
# GROUNDWORK_SEARCH_BACKEND=tavily   # or "local"
# GROUNDWORK_CORPUS=/path/to/corpus  # point offline search at your own docs
# GROUNDWORK_LOG_LEVEL=INFO
